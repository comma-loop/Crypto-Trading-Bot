# ─────────────────────────────────────────────
#  CRYPTO TRADING BOT — ENVIRONMENT CONFIG
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your keys
#  Never commit .env to version control!
# ─────────────────────────────────────────────

# ── MODE ──────────────────────────────────────
# Set to "true" to use demo/testnet accounts
USE_DEMO=true

# ── ACTIVE EXCHANGE ───────────────────────────
# Options: bybit | binance | okx | hyperliquid
EXCHANGE=bybit

# ── BYBIT ─────────────────────────────────────
BYBIT_API_KEY_DEMO=your_bybit_demo_api_key
BYBIT_API_SECRET_DEMO=your_bybit_demo_api_secret
BYBIT_API_KEY_REAL=your_bybit_real_api_key
BYBIT_API_SECRET_REAL=your_bybit_real_api_secret

# ── BINANCE ───────────────────────────────────
BINANCE_API_KEY_DEMO=your_binance_demo_api_key
BINANCE_API_SECRET_DEMO=your_binance_demo_api_secret
BINANCE_API_KEY_REAL=your_binance_real_api_key
BINANCE_API_SECRET_REAL=your_binance_real_api_secret

# ── OKX ───────────────────────────────────────
OKX_API_KEY_DEMO=your_okx_demo_api_key
OKX_API_SECRET_DEMO=your_okx_demo_api_secret
OKX_PASSPHRASE_DEMO=your_okx_demo_passphrase
OKX_API_KEY_REAL=your_okx_real_api_key
OKX_API_SECRET_REAL=your_okx_real_api_secret
OKX_PASSPHRASE_REAL=your_okx_real_passphrase

# ── HYPERLIQUID ───────────────────────────────
HYPERLIQUID_API_KEY_DEMO=your_hl_demo_wallet_address
HYPERLIQUID_API_SECRET_DEMO=your_hl_demo_private_key
HYPERLIQUID_API_KEY_REAL=your_hl_real_wallet_address
HYPERLIQUID_API_SECRET_REAL=your_hl_real_private_key

# ── TRADING SYMBOLS ───────────────────────────
# Bot only trades BTC and ETH — any other coin will be ignored.
# Bybit/OKX/Hyperliquid format: BTC/USDT:USDT
# Binance format:               BTC/USDT:USDT
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT

# ── RISK MANAGEMENT ───────────────────────────
# Fraction of account balance to risk per trade (0.01 = 1%)
RISK_PER_TRADE=0.01
# Maximum number of concurrent open positions per symbol
MAX_POSITIONS_PER_SYMBOL=1
# Leverage (1 = no leverage, use carefully)
LEVERAGE=1

# ── INDICATOR PARAMETERS ─────────────────────
ADX_PERIOD=14
ATR_PERIOD=14
DONCHIAN_PERIOD=20

# ── ADX THRESHOLDS ───────────────────────────
# ADX above this → market is trending → use Donchian strategy
ADX_TREND_THRESHOLD=25
# ADX below this → market is ranging → use Turtle Soup strategy
ADX_RANGE_THRESHOLD=20

# ── DONCHIAN STRATEGY SL/TP ──────────────────
# SL distance = this multiplier × ATR (wide to avoid wicks)
DONCHIAN_SL_ATR_MULT=3.0
# ATR trailing stop distance multiplier
DONCHIAN_TRAIL_ATR_MULT=2.0

# ── TURTLE SOUP STRATEGY SL/TP ───────────────
# Fixed per spec: 1.5×ATR stop, 1.0×ATR target
TURTLE_SL_ATR_MULT=1.5
TURTLE_TP_ATR_MULT=1.0

# ── LOGGING ───────────────────────────────────
LOG_LEVEL=INFO
